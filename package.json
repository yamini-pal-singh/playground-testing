{
  "name": "asr-testing",
  "version": "1.0.0",
  "description": "ASR (Automatic Speech Recognition) API automation testing with Playwright",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:zero-indic": "playwright test src/tests/zeroIndic.spec.ts",
    "test:zero-codeswitch": "playwright test src/tests/zeroCodeswitch.spec.ts",
    "test:zero-stt": "playwright test src/tests/zeroStt.spec.ts",
    "test:translation": "playwright test src/tests/translation.spec.ts",
    "test:transliteration": "playwright test src/tests/transliteration.spec.ts",
    "test:diarization": "playwright test src/tests/diarization.spec.ts",
    "test:word-timestamps": "playwright test src/tests/wordTimestamps.spec.ts",
    "test:summarization": "playwright test src/tests/summarization.spec.ts",
    "test:intent-detection": "playwright test src/tests/intentDetection.spec.ts",
    "test:sentiment-analysis": "playwright test src/tests/sentimentAnalysis.spec.ts",
    "test:emotion-diarization": "playwright test src/tests/emotionDiarization.spec.ts",
    "test:profanity-hashing": "playwright test src/tests/profanityHashing.spec.ts",
    "test:custom-keyword-hashing": "playwright test src/tests/customKeywordHashing.spec.ts",
    "test:keyword-normalization": "playwright test src/tests/keywordNormalization.spec.ts",
    "test:health": "playwright test src/tests/health.spec.ts",
    "test:speaker": "playwright test src/tests/speaker.spec.ts",
    "test:zero-indic-concurrent": "playwright test src/tests/zeroIndicConcurrent.spec.ts",
    "test:long-audio-indic": "playwright test src/tests/longAudioIndic.spec.ts",
    "test:all": "playwright test src/tests/",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "npx ts-node scripts/generate-test-report.ts",
    "report:open": "npx ts-node scripts/generate-test-report.ts && open reports/ASR-Test-Report-*.html",
    "dashboard": "npx ts-node scripts/generate-dashboard.ts",
    "dashboard:open": "npx ts-node scripts/generate-dashboard.ts && open reports/ASR-QC-Dashboard-*.html",
    "report:long-audio": "npx ts-node scripts/generate-long-audio-report.ts",
    "report:long-audio:open": "npx ts-node scripts/generate-long-audio-report.ts && open reports/Long-Audio-Report.html",
    "test:long-audio:full": "npm run test:long-audio-indic && npm run report:long-audio:open",
    "report:concurrent": "npx ts-node scripts/generate-concurrent-report.ts",
    "report:concurrent:open": "npx ts-node scripts/generate-concurrent-report.ts && open reports/Concurrent-Report.html",
    "test:concurrent:full": "npm run test:zero-indic-concurrent && npm run report:concurrent:open",
    "email:report": "npx ts-node scripts/send-report-email.ts",
    "test:playground-zero-indic": "playwright test src/tests/playgroundZeroIndic.spec.ts --project=api-tests",
    "test:playground-zero-indic:baseline": "playwright test src/tests/playgroundZeroIndic.spec.ts --project=api-tests -g 'Baseline'",
    "test:playground-zero-indic:translation": "playwright test src/tests/playgroundZeroIndic.spec.ts --project=api-tests -g 'Translation'",
    "test:playground-zero-indic:transliteration": "playwright test src/tests/playgroundZeroIndic.spec.ts --project=api-tests -g 'Transliteration'",
    "test:playground-zero-indic:diarization": "playwright test src/tests/playgroundZeroIndic.spec.ts --project=api-tests -g 'Diarization'",
    "test:playground-zero-indic:timestamps": "playwright test src/tests/playgroundZeroIndic.spec.ts --project=api-tests -g 'Timestamps'",
    "test:playground-zero-indic:profanity": "playwright test src/tests/playgroundZeroIndic.spec.ts --project=api-tests -g 'Profanity'",
    "test:playground-zero-indic:keyword-hash": "playwright test src/tests/playgroundZeroIndic.spec.ts --project=api-tests -g 'Custom Keyword'",
    "test:playground-zero-indic:intent": "playwright test src/tests/playgroundZeroIndic.spec.ts --project=api-tests -g 'Intent'",
    "test:playground-zero-indic:sentiment": "playwright test src/tests/playgroundZeroIndic.spec.ts --project=api-tests -g 'Sentiment'",
    "test:playground-zero-indic:emotion": "playwright test src/tests/playgroundZeroIndic.spec.ts --project=api-tests -g 'Emotion'",
    "test:playground-zero-indic:summary": "playwright test src/tests/playgroundZeroIndic.spec.ts --project=api-tests -g 'Summarisation'",
    "test:playground-zero-indic:keyword-norm": "playwright test src/tests/playgroundZeroIndic.spec.ts --project=api-tests -g 'Keyword Normalisation'",
    "playground:login": "npx ts-node scripts/save-playground-auth.ts",
    "test:playground-ui": "playwright test src/tests/playgroundUI.spec.ts --project=playground-ui",
    "test:playground-backend": "playwright test src/tests/playgroundBackend.spec.ts --project=api-tests",
    "test:playground-all": "playwright test src/tests/playgroundUI.spec.ts --project=playground-ui && playwright test src/tests/playgroundBackend.spec.ts --project=api-tests",
    "test:playground-daily": "bash scripts/run-playground-daily.sh",
    "report:playground": "npx ts-node scripts/generate-playground-report.ts",
    "report:playground:open": "npx ts-node scripts/generate-playground-report.ts && open reports/Playground-Report.html",
    "test:daily": "bash scripts/run-daily-tests.sh"
  },
  "keywords": [
    "asr",
    "speech-recognition",
    "playwright",
    "api-testing",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/node": "^25.1.0",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.4.5",
    "googleapis": "^144.0.0",
    "typescript": "^5.3.3",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "@types/nodemailer": "^7.0.11",
    "nodemailer": "^8.0.2"
  }
}
